"""TB-05 — Law-0 emission wrapper tests.

Goals:
  - Every strip path covered (verified/weak/missing/pain_points/confidence/
    budget/decision_maker/channel range/lead_score).
  - Pass-through preserves clean output unchanged.
  - Property test: clean pipeline output produces ZERO violations through
    the wrapper. If this test fires, the classifier output format drifted.
"""

import json
import os

from anvil_scout.contracts import ScoredOutput, SignalEvidence, ScrapedInput
from anvil_scout.cli import run_once
from anvil_scout.core.detectors import Span, run_all_detectors
from anvil_scout.core.classifier import classify_signals
from anvil_scout.core.law_zero import enforce_law_zero


def _load_sample(name: str) -> str:
    path = os.path.join(
        os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
        "data",
        name,
    )
    with open(path, "r", encoding="utf-8") as f:
        d = json.load(f)
    return d["website_content"]


def _q(subtype, n=1):
    return [Span(i * 10, i * 10 + 5, "x", "quantity", subtype, 0.9) for i in range(n)]


# ─── strip cases ────────────────────────────────────────────────────────────

class TestStripVerified:

    def test_fabricated_verified_entry_stripped(self):
        out = ScoredOutput()
        out.signal_evidence = SignalEvidence(
            verified=["fabricated nonsense without prefix"],
            weak=[], missing=[], signal_density=0.5, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        assert cleaned.signal_evidence.verified == []
        assert violations >= 1

    def test_valid_prefix_but_no_matching_span_stripped(self):
        """Prefix is in the allowed set but no span backs it → still strip."""
        out = ScoredOutput()
        out.signal_evidence = SignalEvidence(
            verified=["quantity/currency: $999"],
            weak=[], missing=[], signal_density=0.5, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        # No quantity/currency span exists → stripped
        assert cleaned.signal_evidence.verified == []
        assert violations >= 1

    def test_valid_entry_with_matching_span_kept(self):
        out = ScoredOutput()
        out.signal_evidence = SignalEvidence(
            verified=["quantity/currency: $499"],
            weak=[], missing=[], signal_density=0.5, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=_q("currency", 1), thin_scrape=False)
        assert cleaned.signal_evidence.verified == ["quantity/currency: $499"]
        assert violations == 0

    def test_entry_with_classifier_suffix_kept(self):
        """Classifier suffixes after the prefix shouldn't break parsing."""
        out = ScoredOutput()
        out.signal_evidence = SignalEvidence(
            verified=["testimony/social_proof: Trusted by 200 customers. (corroborated by adjacent quantity)"],
            weak=[], missing=[], signal_density=0.5, thin_scrape=False,
        )
        spans = [Span(0, 30, "Trusted by 200 customers", "testimony", "social_proof", 0.8)]
        cleaned, violations = enforce_law_zero(out, spans=spans, thin_scrape=False)
        assert len(cleaned.signal_evidence.verified) == 1
        assert violations == 0


