class TestConfidenceBounds:

    def test_confidence_above_1_clamped(self):
        out = ScoredOutput()
        out.signal_evidence = SignalEvidence(
            verified=[], weak=[], missing=[],
            signal_density=1.5, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        assert cleaned.signal_evidence.signal_density == 1.0
        assert violations >= 1

    def test_confidence_below_0_clamped(self):
        out = ScoredOutput()
        out.signal_evidence = SignalEvidence(
            verified=[], weak=[], missing=[],
            signal_density=-0.3, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        assert cleaned.signal_evidence.signal_density == 0.0
        assert violations >= 1

    def test_thin_scrape_caps_confidence_at_0_2(self):
        out = ScoredOutput()
        out.signal_evidence = SignalEvidence(
            verified=[], weak=[], missing=[],
            signal_density=0.7, thin_scrape=True,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=True)
        assert cleaned.signal_evidence.signal_density == 0.2
        assert violations >= 1

    def test_clean_confidence_unchanged(self):
        out = ScoredOutput()
        out.signal_evidence = SignalEvidence(
            verified=[], weak=[], missing=[],
            signal_density=0.4, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        assert cleaned.signal_evidence.signal_density == 0.4
        assert violations == 0


