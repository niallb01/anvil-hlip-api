class TestChannelClamp:

    def test_industry_fit_over_20_clamped(self):
        out = ScoredOutput()
        out.industry_fit = 99
        out.signal_evidence = SignalEvidence(
            verified=[], weak=[], missing=[], signal_density=0.5, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        assert cleaned.industry_fit == 20
        # And lead_score is recomputed to match
        assert cleaned.lead_score == 20
        assert violations >= 1

    def test_negative_channel_clamped_to_zero(self):
        out = ScoredOutput()
        out.company_size_fit = -5
        out.signal_evidence = SignalEvidence(
            verified=[], weak=[], missing=[], signal_density=0.5, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        assert cleaned.company_size_fit == 0
        assert violations >= 1


class TestLeadScoreRecompute:

    def test_tampered_lead_score_recomputed(self):
        out = ScoredOutput()
        out.industry_fit = 10
        out.company_size_fit = 10
        out.decision_maker_seniority = 10
        out.budget_likelihood_score = 10
        out.growth_signals = 10
        out.lead_score = 99   # tampered — actual sum is 50
        out.signal_evidence = SignalEvidence(
            verified=[], weak=[], missing=[], signal_density=0.5, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        assert cleaned.lead_score == 50
        assert violations >= 1

    def test_clean_lead_score_unchanged(self):
        out = ScoredOutput()
        out.industry_fit = 5
        out.company_size_fit = 5
        out.decision_maker_seniority = 5
        out.budget_likelihood_score = 5
        out.growth_signals = 5
        out.lead_score = 25
        out.signal_evidence = SignalEvidence(
            verified=[], weak=[], missing=[], signal_density=0.5, thin_scrape=False,
        )
        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        assert cleaned.lead_score == 25
        assert violations == 0


# ─── pass-through and property tests ───────────────────────────────────────

class TestPassThrough:

    def test_clean_classifier_output_produces_zero_violations(self):
        """JB-05-1: end-to-end pass through with real pipeline → 0 violations.

        If this test ever fires, the classifier's output prefix format has
        drifted from `<kind>/<subtype>:`. Fix the wrapper's _VALID_VW_PREFIXES
        or fix the classifier.
        """
        text = _load_sample("sample_input.json")
        spans = run_all_detectors(text)
        verified, weak, missing = classify_signals(spans)

        out = ScoredOutput()
        out.signal_evidence = SignalEvidence(
            verified=verified, weak=weak, missing=missing,
            signal_density=0.8, thin_scrape=False,
        )
        out.industry_fit = 20
        out.company_size_fit = 10
        out.decision_maker_seniority = 20
        out.budget_likelihood_score = 20
        out.growth_signals = 10
        out.lead_score = 80
        out.budget_likelihood = "high"
        out.decision_maker = True
        out.pain_points = []

        cleaned, violations = enforce_law_zero(out, spans=spans, thin_scrape=False)
        assert violations == 0, (
            f"Clean classifier output should pass through with 0 violations; got {violations}.\n"
            "If the classifier output format changed, sync _VALID_VW_PREFIXES."
        )
        # Same content survives
        assert cleaned.lead_score == 80
        assert len(cleaned.signal_evidence.verified) == len(verified)


class TestFuzz:

    def test_compound_tampering(self):
        """Multiple tamperings at once → all caught, output is clean."""
        out = ScoredOutput()
        out.industry_fit = 99             # over-range
        out.company_size_fit = -10        # negative
        out.decision_maker_seniority = 20
        out.budget_likelihood_score = 20
        out.growth_signals = 15
        out.lead_score = 1000             # tampered
        out.budget_likelihood = "infinite"  # invalid enum
        out.decision_maker = 1              # not bool
        out.pain_points = ["invented", "fabricated", "made-up"]
        out.signal_evidence = SignalEvidence(
            verified=["nope", "quantity/currency: $999"],   # both wrong
            weak=["pure fiction"],
            missing=["uninstalled category absent from page"],
            signal_density=2.5,
            thin_scrape=False,
        )

        cleaned, violations = enforce_law_zero(out, spans=[], thin_scrape=False)
        # Lots of violations expected
        assert violations >= 10
        # Output is clean
        assert 0 <= cleaned.industry_fit <= 20
        assert 0 <= cleaned.company_size_fit <= 25
        assert cleaned.budget_likelihood in ("high", "medium", "low")
        assert isinstance(cleaned.decision_maker, bool)
        assert cleaned.pain_points == []
        assert cleaned.signal_evidence.verified == []
        assert cleaned.signal_evidence.weak == []
        assert cleaned.signal_evidence.missing == []
        assert 0.0 <= cleaned.signal_evidence.signal_density <= 1.0
        # lead_score recomputed correctly
        assert cleaned.lead_score == (
            cleaned.industry_fit
            + cleaned.company_size_fit
            + cleaned.decision_maker_seniority
            + cleaned.budget_likelihood_score
            + cleaned.growth_signals
        )


# ─── integration via CLI ───────────────────────────────────────────────────

class TestCLIIntegration:

    def test_real_cli_run_has_zero_violations(self):
        """The real CLI pipeline must pass through Law-0 with 0 violations."""
        inp = json.dumps({
            "name": "Jane Doe",
            "title": "Head of Sales",
            "company": "Acme",
            "website_url": "",
            "website_content": _load_sample("sample_input.json"),
        })
        out = json.loads(run_once(inp))
        # If violations occurred, rationale would say so. Clean run → no [Law-0:] tag.
        # (CLI adds the tag only when violations > 0; see test_cli.py.)
        assert "[Law-0:" not in out["rationale"]
