def test_cli_rationale_includes_enrichment_status():
    """TB-07: every CLI run surfaces enrichment status in rationale."""
    inp = json.dumps({
        "name": "Jane", "title": "Head of Sales", "company": "Acme",
        "website_url": "",
        "website_content": "Acme is a B2B SaaS platform. " * 30,
    })
    out = json.loads(run_once(inp))
    assert "Enrichment:" in out["rationale"]


def test_cli_default_provider_shows_unavailable():
    """TB-07: default StubProvider → rationale notes no provider configured."""
    from anvil_scout.core.enrichment import reset_provider
    reset_provider()  # belt-and-braces

    inp = json.dumps({
        "name": "", "title": "", "company": "",
        "website_url": "", "website_content": "Padding text. " * 50,
    })
    out = json.loads(run_once(inp))
    r = out["rationale"]
    # Either phrasing is acceptable: "unavailable (...)" or "no provider configured"
    assert ("unavailable" in r) or ("no provider configured" in r)


def test_cli_rationale_still_schema_clean_with_enrichment():
    """TB-07: adding enrichment to rationale does not break schema validation."""
    inp = json.dumps({
        "name": "Jane", "title": "Head of Sales", "company": "Acme",
        "website_url": "",
        "website_content": "Acme is a B2B SaaS platform. " * 30,
    })
    out = json.loads(run_once(inp))
    # Schema validator note: only fires on actual violation
    assert "[Schema-violation:" not in out["rationale"]
    # Law-0 wrapper too
    assert "[Law-0:" not in out["rationale"]
