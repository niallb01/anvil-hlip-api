def test_cli_clean_run_has_no_law_zero_note():
    """TB-05: a clean pipeline run should produce 0 violations → no [Law-0:] tag."""
    inp = json.dumps({
        "name": "Jane", "title": "Head of Sales", "company": "Acme",
        "website_url": "",
        "website_content": (
            "Acme is the leading B2B SaaS platform. Founded in 2019. "
            "Trusted by over 200 customers. Pricing starts at $499/month. "
            "Enterprise customers get a 99.95% uptime SLA. "
            "We are hiring across engineering, sales, and customer success. "
            "Our automation enables teams to scale revenue by 40%."
        ),
    })
    out = json.loads(run_once(inp))
    assert "[Law-0:" not in out["rationale"]


def test_cli_thin_run_also_clean_through_law_zero():
    """TB-05: thin scrape goes through Law-0 cleanly too."""
    inp = json.dumps({
        "name": "", "title": "Founder", "company": "",
        "website_url": "",
        "website_content": "Coming soon. We're building something cool.",
    })
    out = json.loads(run_once(inp))
    assert "[Law-0:" not in out["rationale"]
    # And the output is still schema-shaped
    assert "lead_score" in out
    assert "signal_evidence" in out


def test_cli_output_passes_schema_after_law_zero():
    """TB-05: Law-0 wrapper output remains SCHEMA.json-compatible."""
    import os
    import json as _json
    schema_path = os.path.join(
        os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
        "SCHEMA.json",
    )
    with open(schema_path, "r", encoding="utf-8") as f:
        schema = _json.load(f)
    required = set(schema["required"])

    inp = json.dumps({
        "name": "Jane", "title": "VP Sales", "company": "Acme",
        "website_url": "",
        "website_content": "Acme. " * 100,  # rich enough to populate fields
    })
    out = json.loads(run_once(inp))
    assert set(required).issubset(set(out.keys())), (
        f"missing required fields: {set(required) - set(out.keys())}"
    )
    # signal_evidence sub-fields
    se = out["signal_evidence"]
    se_required = set(schema["properties"]["signal_evidence"]["required"])
    assert se_required.issubset(set(se.keys()))


