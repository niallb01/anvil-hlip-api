    """TB-04: pain_points must be empty list. No fabrication."""
    inp = json.dumps({
        "name": "Jane", "title": "CEO", "company": "Acme",
        "website_url": "",
        "website_content": "Long content about pain points around sales efficiency and lead quality. " * 20,
    })
    out = json.loads(run_once(inp))
    assert out["pain_points"] == []


def test_cli_rationale_includes_channel_scores():
    """TB-04: rationale must include all 5 channel scores."""
    inp = json.dumps({
        "name": "Jane", "title": "Head of Sales", "company": "Acme",
        "website_url": "",
        "website_content": "Acme is a leading B2B SaaS platform. " * 20,
    })
    out = json.loads(run_once(inp))
    rationale = out["rationale"]
    assert "industry_fit=" in rationale
    assert "company_size_fit=" in rationale
    assert "decision_maker_seniority=" in rationale
    assert "budget_likelihood_score=" in rationale
    assert "growth_signals=" in rationale
    assert "lead_score=" in rationale


def test_cli_decision_maker_flag_matches_seniority_threshold():
    """TB-04: decision_maker is True iff seniority >= 15."""
    # IC role → seniority 5 → decision_maker False
    out_ic = json.loads(run_once(json.dumps({
        "name": "", "title": "Software Engineer", "company": "",
        "website_url": "", "website_content": "Padding text " * 50,
    })))
    assert out_ic["decision_maker_seniority"] == 5
    assert out_ic["decision_maker"] is False

    # Senior role → seniority 15 → decision_maker True
    out_senior = json.loads(run_once(json.dumps({
        "name": "", "title": "Senior Sales Manager", "company": "",
        "website_url": "", "website_content": "Padding text " * 50,
    })))
    assert out_senior["decision_maker_seniority"] == 15
    assert out_senior["decision_maker"] is True


def test_cli_lead_score_equals_channel_sum():
    """TB-04: lead_score must equal the sum of the 5 channels."""
    inp = json.dumps({
        "name": "Jane", "title": "Director of Sales", "company": "Acme",
        "website_url": "",
        "website_content": (
            "Acme is the leading B2B SaaS platform. Pricing starts at $499/month. "
            "Trusted by over 200 customers. 99.95% uptime SLA. We are hiring "
            "engineers. Founded in 2019. Our automation enables teams to scale."
        ),
    })
    out = json.loads(run_once(inp))
    expected = (
        out["industry_fit"]
        + out["company_size_fit"]
        + out["decision_maker_seniority"]
        + out["budget_likelihood_score"]
        + out["growth_signals"]
    )
    assert out["lead_score"] == expected


