{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnvilScoutOutput",
  "type": "object",
  "required": [
    "lead_score",
    "industry_fit",
    "company_size_fit",
    "decision_maker_seniority",
    "budget_likelihood_score",
    "growth_signals",
    "pain_points",
    "budget_likelihood",
    "decision_maker",
    "rationale",
    "signal_evidence"
  ],
  "properties": {
    "lead_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "industry_fit": { "type": "integer", "minimum": 0, "maximum": 20 },
    "company_size_fit": { "type": "integer", "minimum": 0, "maximum": 25 },
    "decision_maker_seniority": { "type": "integer", "minimum": 0, "maximum": 20 },
    "budget_likelihood_score": { "type": "integer", "minimum": 0, "maximum": 20 },
    "growth_signals": { "type": "integer", "minimum": 0, "maximum": 15 },
    "pain_points": { "type": "array", "items": { "type": "string" } },
    "budget_likelihood": { "type": "string", "enum": ["high", "medium", "low"] },
    "decision_maker": { "type": "boolean" },
    "rationale": { "type": "string" },
    "signal_evidence": {
      "type": "object",
      "required": ["verified", "weak", "missing", "confidence", "thin_scrape"],
      "properties": {
        "verified": { "type": "array", "items": { "type": "string" } },
        "weak": { "type": "array", "items": { "type": "string" } },
        "missing": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "thin_scrape": { "type": "boolean" }
      }
    }
  }
}
